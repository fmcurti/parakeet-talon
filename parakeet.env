# VAD knobs for the parakeet sidecar. Uncomment and tweak values to override.
# Anything commented uses the sidecar's built-in default; resolved values
# print to stderr / talon.log on startup so you can verify the file was read.
#
# Shell / system env vars take precedence over this file, so you can still
# override a single run without editing it.

# Mic energy floor, 0.0–1.0 scale on normalized samples.
# Raise it (e.g. 0.01) if ambient noise keeps opening phrases.
# Lower it (e.g. 0.002) if the mic is quiet and speech is being ignored.
#PARAKEET_VAD_THRESHOLD=0.005

# Continuous speech needed before a phrase opens. Lower = snappier onset,
# more false triggers from clicks / typing.
#PARAKEET_VAD_START_MS=160

# Trailing silence before we commit the phrase and run decoding. This is the
# main latency knob — lower = commands fire faster but get cut if you pause.
PARAKEET_VAD_END_MS=300

# Discard phrases with less speech than this (filters out mic pops and very
# short noises). Trailing silence doesn't count toward the minimum.
#PARAKEET_VAD_MIN_MS=320

# Force-commit if someone keeps talking past this limit. Mostly a safety net
# so a stuck mic doesn't buffer forever.
#PARAKEET_VAD_MAX_MS=10000

# Audio kept from before the phrase trigger and prepended to it. Recovers
# quiet word onsets (leading consonants) the energy gate misses and gives the
# model some leading-silence padding. 0 disables.
#PARAKEET_VAD_PREROLL_MS=320

# --- qwen engine only ---
# Language the Qwen decoder is forced to. Defaults to english (Talon commands
# are English). Set another language name (e.g. spanish) to force that, or
# "auto" to let the model detect the language per utterance.
#QWEN_LANGUAGE=english
